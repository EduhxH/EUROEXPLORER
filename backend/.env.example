APP_ENV=development
JWT_SECRET_KEY=replace-with-a-long-random-secret
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=europa_explorer
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
SESSION_SECONDS=28800
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=900
MAX_UPLOAD_BYTES=5242880

# Optional first-run account seeding. Prefer a secret manager for production.
# SEED_SUPER_ADMIN_USERNAME=admin
# SEED_SUPER_ADMIN_PASSWORD=replace-with-at-least-10-characters
